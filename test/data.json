[{"name": "Johann Gottlieb Fichte", "school": "German Idealism", "libriVoxIDs": ["8557"], "libriVoxGetRequestLinks": ["https://librivox.org/api/feed/audiobooks/?id=8557&extended=1&format=json"], "birthDate": "19 May 1762", "interests": ["Self-Consciousness and Self-Awareness", "Moral Philosophy", "Political Philosophy"], "iepLink": "https://www.iep.utm.edu/fichtejg/", "birthYear": "1762 AD", "deathDate": "27 January 1814", "deathYear": "1814 AD", "life": "(1762-1814)", "hasEBooks": false, "wikiTitle": "Johann Gottlieb Fichte", "id": "2EE09BAD-1395-4394-8F6F-EB591069AE66", "speLink": "https://plato.stanford.edu/entries/johann-fichte/", "images": {"thumbnailIllustrations": {"thumbnailIll50x50": "/Images/Johann-Gottlieb-Fichte-Ill-small.png", "thumbnailIll100x100": "/Images/Johann-Gottlieb-Fichte-Ill-small@2x.png", "thumbnailIll150x150": "/Images/Johann-Gottlieb-Fichte-Ill-small@3x.png"}, "illustrations": {"ill750x750": "/Images/Johann-Gottlieb-Fichte-Ill@3x.png", "ill500x500": "/Images/Johann-Gottlieb-Fichte-Ill@2x.png", "ill250x250": "/Images/Johann-Gottlieb-Fichte-Ill.png"}, "fullImages": {"full1260x1680": "/Images/Johann-Gottlieb-FichteFull-iPhone@3x.jpg", "full420x560": "/Images/Johann-Gottlieb-FichteFull-iPhone.jpg", "full840x1120": "/Images/Johann-Gottlieb-FichteFull-iPhone@2x.jpg", "full600x800": "/Images/Johann-Gottlieb-FichteFull.jpg", "full1200x1600": "/Images/Johann-Gottlieb-FichteFull@2x.jpg"}, "faceImages": {"face750x750": "/Images/Johann-Gottlieb-FichteFace@3x.jpg", "face500x500": "/Images/Johann-Gottlieb-FichteFace@2x.jpg", "face250x250": "/Images/Johann-Gottlieb-FichteFace.jpg"}, "imgApiUrl": "https://philosophersapi.com"}, "username": "@JGF", "desc": "Johann Gottlieb Fichte (19 May 1762 \u2013 29 January 1814) was a German philosopher who became a founding figure of German idealism, which developed from the theoretical and ethical writings of Immanuel Kant. \nFichte is an important philosopher in his own right due to his original insights into the nature of self-consciousness or self-awareness. Fichte was also the originator of thesis\u2013antithesis\u2013synthesis, an idea that is often erroneously attributed to Hegel. \nLike Descartes and Kant before him, Fichte was motivated by the problem of subjectivity and consciousness. Fichte also wrote works of political philosophy; he has a reputation as one of the fathers of German nationalism."}]